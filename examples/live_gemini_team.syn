// Live-provider adopter trial: a four-role team plans a constrained project.
// The prompts contain synthetic project data only.

agent ProductAnalyst {
    model "gemini-3.1-flash-lite"

    fn analyze(brief) {
        let analysis = thought {
            step prompt "Act as the product analyst. Project: {brief} Write exactly six compact numbered lines: users; essential journeys; included MVP; excluded scope; measurable acceptance; open questions. Maximum 110 words total. No preamble or table. End with [[PRODUCT_DONE]]."
        } aggregate "chain"
        return analysis
    }
}

agent SystemArchitect {
    model "gemini-3.1-flash-lite"

    fn design(brief, product_analysis) {
        let architecture = thought {
            step prompt "Act as the system architect. Project: {brief} Product analysis: {product_analysis} Write exactly six compact numbered lines: topology; core data; offline storage/sync; conflict rules; security/privacy; deployment, budget, and trade-off. Maximum 120 words total. No preamble or table. End with [[ARCHITECTURE_DONE]]."
        } aggregate "chain"
        return architecture
    }
}

agent RiskReviewer {
    model "gemini-3.1-flash-lite"

    fn review(brief, product_analysis, architecture) {
        let review = thought {
            step prompt "Act as an independent risk reviewer. Project: {brief} Product analysis: {product_analysis} Architecture: {architecture} Challenge the proposal. Write exactly five compact numbered lines, each with severity, risk, and mitigation or scope cut. Maximum 120 words total. No preamble or table. End with [[RISK_DONE]]."
        } aggregate "chain"
        return review
    }
}

agent DeliveryLead {
    model "gemini-3.1-flash-lite"

    fn synthesize(brief, product_analysis, architecture, risk_review) {
        let plan = thought {
            step prompt "Act as the delivery lead. Project: {brief} Product analysis: {product_analysis} Architecture: {architecture} Risk review: {risk_review} Write exactly five compact numbered lines: go/no-go; frozen scope; architecture decision; resolved disagreement; exclusions. Maximum 120 words. No preamble or table. End with [[DECISION_DONE]]."
            step prompt "Using the decision in context, write exactly four compact numbered lines for weeks 1 through 4. Each line must name the week, deliverable, owner among Dev A/B/C, and verification gate. Maximum 120 words. No table. End with [[WEEKS_1_4_DONE]]."
            step prompt "Continue with exactly four compact numbered lines for weeks 5 through 8. Each line must name the week, deliverable, owner, and verification gate; include real-device pilot, budget, restore, and rollback. Maximum 120 words. No table. End with [[WEEKS_5_8_DONE]]."
            step prompt "Audit the plan in context. Write exactly five compact numbered lines: three top risks with owners; deferred work; final success standard requiring evidence beyond exit code zero. Maximum 120 words. No table. End with [[AUDIT_DONE]]."
        } aggregate "chain"
        return plan
    }
}

fn main() {
    let project_brief = "Build Beacon, an offline-first web application for coordinating community volunteers during connectivity outages. It must serve 200 active volunteers, minimize personal data, reconcile conflicting edits made on phones, retain an auditable assignment history, fit a three-developer team and eight-week delivery window, and keep infrastructure below 500 EUR per month. The result must be a buildable MVP plan."

    let analyst = ProductAnalyst()
    let architect = SystemArchitect()
    let reviewer = RiskReviewer()
    let lead = DeliveryLead()

    let product_analysis = analyst.analyze(project_brief)
    print("=== PRODUCT ANALYSIS ===")
    print(product_analysis)

    let architecture = architect.design(project_brief, product_analysis)
    print("=== ARCHITECTURE ===")
    print(architecture)

    let risk_review = reviewer.review(project_brief, product_analysis, architecture)
    print("=== RISK REVIEW ===")
    print(risk_review)

    let final_plan = lead.synthesize(project_brief, product_analysis, architecture, risk_review)
    print("=== FINAL DELIVERY PLAN ===")
    print(final_plan)
}
