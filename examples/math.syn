// Математические вычисления
fn factorial(n) {
    if n <= 1 {
        return 1
    }
    return n * factorial(n - 1)
}

fn main() {
    let f5 = factorial(5)
    print(f5)

    let nums = [3, 1, 4, 1, 5, 9]
    let sorted_nums = sorted(nums)
    print(sorted_nums)

    let max_val = max(nums)
    print(max_val)
}
